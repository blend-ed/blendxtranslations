#: static/proctoring/js/views/proctored_exam_info.js:14
msgid "You have not started your onboarding exam."
msgstr "ਤੁਸੀਂ ਆਪਣੀ ਆਨਬੋਰਡਿੰਗ ਪ੍ਰੀਖਿਆ ਸ਼ੁਰੂ ਨਹੀਂ ਕੀਤੀ ਹੈ।"

