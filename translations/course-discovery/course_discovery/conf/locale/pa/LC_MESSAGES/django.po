#: apps/api/filters.py:48
#, python-brace-format
msgid "No user with the username [{username}] exists."
msgstr "ਯੂਜ਼ਰਨੇਮ [{username}] ਵਾਲਾ ਕੋਈ ਯੂਜ਼ਰ ਮੌਜੂਦ ਨਹੀਂ ਹੈ।"

#: apps/api/filters.py:51
msgid ""
"Only staff users are permitted to filter by username. Remove the username "
"parameter."
msgstr ""
"ਸਿਰਫ਼ ਸਟਾਫ਼ ਉਪਭੋਗਤਾਵਾਂ ਨੂੰ ਹੀ ਉਪਭੋਗਤਾ ਨਾਮ ਦੁਆਰਾ ਫਿਲਟਰ ਕਰਨ ਦੀ ਆਗਿਆ ਹੈ। "
"ਉਪਭੋਗਤਾ ਨਾਮ ਪੈਰਾਮੀਟਰ ਹਟਾਓ।"

#: apps/api/serializers.py:850
msgid "Number of courses contained in this catalog"
msgstr "ਇਸ ਕੈਟਾਲਾਗ ਵਿੱਚ ਸ਼ਾਮਲ ਕੋਰਸਾਂ ਦੀ ਗਿਣਤੀ"

#: apps/api/serializers.py:853
msgid "Usernames of users with explicit access to view this catalog"
msgstr "ਇਸ ਕੈਟਾਲਾਗ ਨੂੰ ਦੇਖਣ ਲਈ ਸਪਸ਼ਟ ਪਹੁੰਚ ਵਾਲੇ ਉਪਭੋਗਤਾਵਾਂ ਦੇ ਉਪਭੋਗਤਾ ਨਾਮ"

#: apps/api/serializers.py:1023
msgid "Start date cannot be after the End date"
msgstr "ਸ਼ੁਰੂਆਤੀ ਮਿਤੀ ਸਮਾਪਤੀ ਮਿਤੀ ਤੋਂ ਬਾਅਦ ਦੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"

#: apps/api/serializers.py:1028
msgid "Term cannot be changed"
msgstr "ਮਿਆਦ ਬਦਲੀ ਨਹੀਂ ਜਾ ਸਕਦੀ।"

#: apps/api/serializers.py:1048
msgid "Language in which the course is administered"
msgstr "ਉਹ ਭਾਸ਼ਾ ਜਿਸ ਵਿੱਚ ਕੋਰਸ ਚਲਾਇਆ ਜਾਂਦਾ ਹੈ"

#: apps/api/serializers.py:1152
msgid "Course cannot be changed for an existing course run"
msgstr "ਮੌਜੂਦਾ ਕੋਰਸ ਲਈ ਕੋਰਸ ਬਦਲਿਆ ਨਹੀਂ ਜਾ ਸਕਦਾ।"

#: apps/api/serializers.py:1157
msgid "Minimum effort cannot be greater than Maximum effort"
msgstr "ਘੱਟੋ-ਘੱਟ ਕੋਸ਼ਿਸ਼ ਵੱਧ ਤੋਂ ਵੱਧ ਕੋਸ਼ਿਸ਼ ਤੋਂ ਵੱਧ ਨਹੀਂ ਹੋ ਸਕਦੀ।"

#: apps/api/serializers.py:1159
msgid "Minimum effort and Maximum effort cannot be the same"
msgstr "ਘੱਟੋ-ਘੱਟ ਕੋਸ਼ਿਸ਼ ਅਤੇ ਵੱਧ ਤੋਂ ਵੱਧ ਕੋਸ਼ਿਸ਼ ਇੱਕੋ ਜਿਹੀ ਨਹੀਂ ਹੋ ਸਕਦੀ।"

#: apps/api/serializers.py:1205
msgid "Dictionary mapping course run IDs to boolean values"
msgstr "ਡਿਕਸ਼ਨਰੀ ਮੈਪਿੰਗ ਕੋਰਸ ਬੂਲੀਅਨ ਮੁੱਲਾਂ ਲਈ ID ਚਲਾਓ"

#: apps/api/serializers.py:1309
msgid "Restriction Type cannot be empty"
msgstr "ਪਾਬੰਦੀ ਦੀ ਕਿਸਮ ਖਾਲੀ ਨਹੀਂ ਹੋ ਸਕਦੀ"

#: apps/api/serializers.py:1775
msgid "Dictionary mapping course IDs to boolean values"
msgstr "ਡਿਕਸ਼ਨਰੀ ਮੈਪਿੰਗ ਕੋਰਸ ਆਈਡੀਜ਼ ਨੂੰ ਬੂਲੀਅਨ ਮੁੱਲਾਂ ਨਾਲ ਜੋੜਦੀ ਹੈ"

#: apps/api/serializers.py:2242
msgid "Languages that course runs in this program are offered in."
msgstr ""
"ਇਸ ਪ੍ਰੋਗਰਾਮ ਵਿੱਚ ਜਿਨ੍ਹਾਂ ਭਾਸ਼ਾਵਾਂ ਵਿੱਚ ਕੋਰਸ ਚਲਾਇਆ ਜਾਂਦਾ ਹੈ, ਉਨ੍ਹਾਂ ਵਿੱਚ "
"ਪੇਸ਼ਕਸ਼ ਕੀਤੀ ਜਾਂਦੀ ਹੈ।"

#: apps/api/serializers.py:2246
msgid ""
"Languages that course runs in this program have available transcripts in."
msgstr ""
"ਇਸ ਪ੍ਰੋਗਰਾਮ ਵਿੱਚ ਜਿਨ੍ਹਾਂ ਭਾਸ਼ਾਵਾਂ ਵਿੱਚ ਕੋਰਸ ਚਲਾਇਆ ਜਾਂਦਾ ਹੈ, ਉਨ੍ਹਾਂ ਵਿੱਚ "
"ਟ੍ਰਾਂਸਕ੍ਰਿਪਟ ਉਪਲਬਧ ਹਨ।"

#: apps/api/utils.py:346
#, python-brace-format
msgid ""
"An error occurred while setting the course run image for [{key}] in studio. "
"All other fields were successfully saved in Studio."
msgstr ""
"ਸਟੂਡੀਓ ਵਿੱਚ [{key}] ਲਈ ਕੋਰਸ ਰਨ ਇਮੇਜ ਸੈੱਟ ਕਰਨ ਵੇਲੇ ਇੱਕ ਗਲਤੀ ਆਈ। ਬਾਕੀ ਸਾਰੇ "
"ਖੇਤਰ ਸਟੂਡੀਓ ਵਿੱਚ ਸਫਲਤਾਪੂਰਵਕ ਸੁਰੱਖਿਅਤ ਕੀਤੇ ਗਏ ਸਨ।"

#: apps/api/v1/exceptions.py:13
msgid "Specifying both editable=1 and a q parameter is not supported."
msgstr "ਸੰਪਾਦਨਯੋਗ=1 ਅਤੇ aq ਪੈਰਾਮੀਟਰ ਦੋਵਾਂ ਨੂੰ ਨਿਰਧਾਰਤ ਕਰਨਾ ਸਮਰਥਿਤ ਨਹੀਂ ਹੈ।"

#: apps/api/v1/views/comments.py:34
msgid "You must include a course_uuid in your query parameters."
msgstr ""
"ਤੁਹਾਨੂੰ ਆਪਣੇ ਪੁੱਛਗਿੱਛ ਪੈਰਾਮੀਟਰਾਂ ਵਿੱਚ ਇੱਕ course_uuid ਸ਼ਾਮਲ ਕਰਨਾ ਚਾਹੀਦਾ ਹੈ।"

#: apps/api/v1/views/comments.py:58 apps/api/v1/views/courses.py:205
#, python-brace-format
msgid "Missing value for: [{name}]. "
msgstr "ਇਸ ਲਈ ਮੁੱਲ ਗੁੰਮ ਹੈ: [{name}]।"

#: apps/api/v1/views/comments.py:60 apps/api/v1/views/courses.py:216
msgid "Incorrect data sent. "
msgstr "ਗਲਤ ਡਾਟਾ ਭੇਜਿਆ ਗਿਆ।"

#: apps/api/v1/views/course_runs.py:49
msgid "Failed to set course run data: {}"
msgstr "ਕੋਰਸ ਰਨ ਡੇਟਾ ਸੈੱਟ ਕਰਨ ਵਿੱਚ ਅਸਫਲ: {}"

#: apps/api/v1/views/course_runs.py:328
msgid "Can only update status, ofac restrictions, and ofac comment"
msgstr ""
"ਸਿਰਫ਼ ਸਥਿਤੀ, ofac ਪਾਬੰਦੀਆਂ, ਅਤੇ ofac ਟਿੱਪਣੀ ਨੂੰ ਅੱਪਡੇਟ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ"

#: apps/api/v1/views/course_runs.py:363
#, python-brace-format
msgid ""
"The course run type '{course_run_type}' is not valid for this course type "
"'{course_type}'."
msgstr ""
"ਇਸ ਕੋਰਸ ਕਿਸਮ '{course_type}' ਲਈ ਕੋਰਸ ਰਨ ਕਿਸਮ '{course_run_type}' ਵੈਧ ਨਹੀਂ "
"ਹੈ।"

#: apps/api/v1/views/course_runs.py:381
msgid "Course run is in review. Editing disabled."
msgstr "ਕੋਰਸ ਰਨ ਸਮੀਖਿਆ ਅਧੀਨ ਹੈ। ਸੰਪਾਦਨ ਅਯੋਗ ਹੈ।"

#: apps/api/v1/views/course_runs.py:388
msgid "Invalid parameter"
msgstr "ਅਵੈਧ ਪੈਰਾਮੀਟਰ"

#: apps/api/v1/views/courses.py:62
msgid "Failed to set data: {}"
msgstr "ਡਾਟਾ ਸੈੱਟ ਕਰਨ ਵਿੱਚ ਅਸਫਲ: {}"

#: apps/api/v1/views/courses.py:207
#, python-brace-format
msgid "Organization [{org}] does not exist. "
msgstr "ਸੰਗਠਨ [{org}] ਮੌਜੂਦ ਨਹੀਂ ਹੈ।"

#: apps/api/v1/views/courses.py:209
#, python-brace-format
msgid "Course Type [{course_type}] does not exist. "
msgstr "ਕੋਰਸ ਕਿਸਮ [{course_type}] ਮੌਜੂਦ ਨਹੀਂ ਹੈ।"

#: apps/api/v1/views/courses.py:212
#, python-brace-format
msgid "Product Source [{product_source}] does not exist. "
msgstr "ਉਤਪਾਦ ਸਰੋਤ [{product_source}] ਮੌਜੂਦ ਨਹੀਂ ਹੈ।"

#: apps/api/v1/views/courses.py:229
#, python-brace-format
msgid "A course with key [{key}] already exists."
msgstr "[{key}] ਕੁੰਜੀ ਵਾਲਾ ਇੱਕ ਕੋਰਸ ਪਹਿਲਾਂ ਹੀ ਮੌਜੂਦ ਹੈ।"

#: apps/api/v1/views/courses.py:237
#, python-brace-format
msgid ""
"Course creation was unsuccessful. The course URL slug ‘[{url_slug}]’ is "
"already in use. Please update this field and try again."
msgstr ""
"ਕੋਰਸ ਬਣਾਉਣਾ ਅਸਫਲ ਰਿਹਾ। ਕੋਰਸ URL ਸਲੱਗ ‘[{url_slug}]’ ਪਹਿਲਾਂ ਹੀ ਵਰਤੋਂ ਵਿੱਚ ਹੈ।"
" ਕਿਰਪਾ ਕਰਕੇ ਇਸ ਖੇਤਰ ਨੂੰ ਅੱਪਡੇਟ ਕਰੋ ਅਤੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"

#: apps/api/v1/views/courses.py:298
msgid ""
"Switching entitlement types after being reviewed is not supported. Please "
"reach out to your project coordinator for additional help if necessary."
msgstr ""
"ਸਮੀਖਿਆ ਕੀਤੇ ਜਾਣ ਤੋਂ ਬਾਅਦ ਹੱਕਦਾਰੀ ਕਿਸਮਾਂ ਨੂੰ ਬਦਲਣਾ ਸਮਰਥਿਤ ਨਹੀਂ ਹੈ। ਜੇਕਰ ਲੋੜ "
"ਹੋਵੇ ਤਾਂ ਵਾਧੂ ਮਦਦ ਲਈ ਕਿਰਪਾ ਕਰਕੇ ਆਪਣੇ ਪ੍ਰੋਜੈਕਟ ਕੋਆਰਡੀਨੇਟਰ ਨਾਲ ਸੰਪਰਕ ਕਰੋ।"

#: apps/api/v1/views/courses.py:408
#, python-brace-format
msgid ""
"Course edit was unsuccessful. The course URL slug ‘[{url_slug}]’ is already "
"in use. Please update this field and try again."
msgstr ""
"ਕੋਰਸ ਸੰਪਾਦਨ ਅਸਫਲ ਰਿਹਾ। ਕੋਰਸ URL ਸਲੱਗ ‘[{url_slug}]’ ਪਹਿਲਾਂ ਹੀ ਵਰਤੋਂ ਵਿੱਚ ਹੈ।"
" ਕਿਰਪਾ ਕਰਕੇ ਇਸ ਖੇਤਰ ਨੂੰ ਅੱਪਡੇਟ ਕਰੋ ਅਤੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"

#: apps/api/views.py:58
msgid "You are not permitted to access the API documentation."
msgstr "ਤੁਹਾਨੂੰ API ਦਸਤਾਵੇਜ਼ਾਂ ਤੱਕ ਪਹੁੰਚ ਕਰਨ ਦੀ ਇਜਾਜ਼ਤ ਨਹੀਂ ਹੈ।"

