#: models.py:39
msgid "Display Correctness?"
msgstr "ਡਿਸਪਲੇ ਦੀ ਸ਼ੁੱਧਤਾ?"

#: models.py:41
msgid ""
"This is a flag that indicates if the indicator icon should be displayed "
"after a student enters their response"
msgstr ""
"ਇਹ ਇੱਕ ਫਲੈਗ ਹੈ ਜੋ ਦਰਸਾਉਂਦਾ ਹੈ ਕਿ ਕੀ ਵਿਦਿਆਰਥੀ ਦੇ ਜਵਾਬ ਦਰਜ ਕਰਨ ਤੋਂ ਬਾਅਦ ਸੂਚਕ "
"ਆਈਕਨ ਪ੍ਰਦਰਸ਼ਿਤ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"

#: models.py:49
msgid "Display Other Student Responses"
msgstr "ਹੋਰ ਵਿਦਿਆਰਥੀਆਂ ਦੇ ਜਵਾਬ ਪ੍ਰਦਰਸ਼ਿਤ ਕਰੋ"

#: models.py:51
msgid ""
"This will display other student responses to the student after they submit "
"their response."
msgstr ""
"ਇਹ ਵਿਦਿਆਰਥੀ ਵੱਲੋਂ ਆਪਣਾ ਜਵਾਬ ਜਮ੍ਹਾਂ ਕਰਨ ਤੋਂ ਬਾਅਦ ਹੋਰ ਵਿਦਿਆਰਥੀ ਜਵਾਬਾਂ ਨੂੰ "
"ਪ੍ਰਦਰਸ਼ਿਤ ਕਰੇਗਾ।"

#: models.py:60
msgid "System selected answers to give to students"
msgstr "ਵਿਦਿਆਰਥੀਆਂ ਨੂੰ ਦੇਣ ਲਈ ਸਿਸਟਮ ਚੁਣੇ ਹੋਏ ਉੱਤਰ"

#: models.py:63
msgid "Display Name"
msgstr "ਦਿਖਾਇਆ ਹੋਇਆ ਨਾਮ"

#: models.py:65
msgid "This is the title for this question type"
msgstr "ਇਹ ਇਸ ਪ੍ਰਸ਼ਨ ਕਿਸਮ ਦਾ ਸਿਰਲੇਖ ਹੈ।"

#: models.py:71
msgid "Full-Credit Key Phrases"
msgstr "ਪੂਰੇ-ਕ੍ਰੈਡਿਟ ਮੁੱਖ ਵਾਕਾਂਸ਼"

#: models.py:73
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive full credit"
msgstr ""
"ਇਹ ਸ਼ਬਦਾਂ ਜਾਂ ਵਾਕਾਂਸ਼ਾਂ ਦੀ ਇੱਕ ਸੂਚੀ ਹੈ, ਜਿਨ੍ਹਾਂ ਵਿੱਚੋਂ ਇੱਕ ਮੌਜੂਦ ਹੋਣਾ ਲਾਜ਼ਮੀ"
" ਹੈ ਤਾਂ ਜੋ ਵਿਦਿਆਰਥੀ ਦੇ ਉੱਤਰ ਨੂੰ ਪੂਰਾ ਕ੍ਰੈਡਿਟ ਮਿਲ ਸਕੇ।"

#: models.py:81
msgid "Half-Credit Key Phrases"
msgstr "ਅੱਧੇ-ਕ੍ਰੈਡਿਟ ਦੇ ਮੁੱਖ ਵਾਕਾਂਸ਼"

#: models.py:83
msgid ""
"This is a list of words or phrases, one of which must be present in order "
"for the student's answer to receive half credit"
msgstr ""
"ਇਹ ਸ਼ਬਦਾਂ ਜਾਂ ਵਾਕਾਂਸ਼ਾਂ ਦੀ ਇੱਕ ਸੂਚੀ ਹੈ, ਜਿਨ੍ਹਾਂ ਵਿੱਚੋਂ ਇੱਕ ਮੌਜੂਦ ਹੋਣਾ ਚਾਹੀਦਾ"
" ਹੈ ਤਾਂ ਜੋ ਵਿਦਿਆਰਥੀ ਦੇ ਉੱਤਰ ਨੂੰ ਅੱਧਾ ਕ੍ਰੈਡਿਟ ਮਿਲ ਸਕੇ।"

#: models.py:91
msgid "Maximum Number of Attempts"
msgstr "ਕੋਸ਼ਿਸ਼ਾਂ ਦੀ ਵੱਧ ਤੋਂ ਵੱਧ ਗਿਣਤੀ"

#: models.py:93
msgid ""
"This is the maximum number of times a student is allowed to attempt the "
"problem"
msgstr ""
"ਇਹ ਵੱਧ ਤੋਂ ਵੱਧ ਗਿਣਤੀ ਹੈ ਜਿੰਨੀ ਵਾਰ ਇੱਕ ਵਿਦਿਆਰਥੀ ਨੂੰ ਸਮੱਸਿਆ ਦਾ ਹੱਲ ਕਰਨ ਦੀ "
"ਇਜਾਜ਼ਤ ਦਿੱਤੀ ਜਾਂਦੀ ਹੈ।"

#: models.py:101
msgid "Maximum Word Count"
msgstr "ਵੱਧ ਤੋਂ ਵੱਧ ਸ਼ਬਦ ਗਿਣਤੀ"

#: models.py:103
msgid "This is the maximum number of words allowed for this question"
msgstr "ਇਸ ਸਵਾਲ ਲਈ ਇਹ ਸ਼ਬਦਾਂ ਦੀ ਵੱਧ ਤੋਂ ਵੱਧ ਸੰਖਿਆ ਹੈ।"

#: models.py:111
msgid "Minimum Word Count"
msgstr "ਘੱਟੋ-ਘੱਟ ਸ਼ਬਦ ਗਿਣਤੀ"

#: models.py:113
msgid "This is the minimum number of words required for this question"
msgstr "ਇਸ ਪ੍ਰਸ਼ਨ ਲਈ ਲੋੜੀਂਦੇ ਘੱਟੋ-ਘੱਟ ਸ਼ਬਦਾਂ ਦੀ ਗਿਣਤੀ ਇਹ ਹੈ।"

#: models.py:121
msgid "Prompt"
msgstr "ਪ੍ਰੋਂਪਟ"

#: models.py:123
msgid ""
"This is the prompt students will see when asked to enter their response"
msgstr ""
"ਇਹ ਉਹ ਪ੍ਰੋਂਪਟ ਹੈ ਜੋ ਵਿਦਿਆਰਥੀਆਂ ਨੂੰ ਆਪਣਾ ਜਵਾਬ ਦਰਜ ਕਰਨ ਲਈ ਕਿਹਾ ਜਾਣ 'ਤੇ ਦਿਖਾਈ "
"ਦੇਵੇਗਾ।"

#: models.py:131
msgid "Submission Received Message"
msgstr "ਸਬਮਿਸ਼ਨ ਪ੍ਰਾਪਤ ਹੋਇਆ ਸੁਨੇਹਾ"

#: models.py:133
msgid "This is the message students will see upon submitting their response"
msgstr "ਇਹ ਉਹ ਸੁਨੇਹਾ ਹੈ ਜੋ ਵਿਦਿਆਰਥੀ ਆਪਣਾ ਜਵਾਬ ਜਮ੍ਹਾਂ ਕਰਨ 'ਤੇ ਦੇਖਣਗੇ।"

#: models.py:140
msgid "Weight"
msgstr "ਭਾਰ"

#: models.py:142
msgid "This assigns an integer value representing the weight of this problem"
msgstr ""
"ਇਹ ਇਸ ਸਮੱਸਿਆ ਦੇ ਭਾਰ ਨੂੰ ਦਰਸਾਉਣ ਵਾਲਾ ਇੱਕ ਪੂਰਨ ਅੰਕ ਮੁੱਲ ਨਿਰਧਾਰਤ ਕਰਦਾ ਹੈ।"

#: models.py:150
msgid "Draft Received Message"
msgstr "ਡਰਾਫਟ ਪ੍ਰਾਪਤ ਸੁਨੇਹਾ"

#: models.py:152
msgid "This is the message students will see upon submitting a draft response"
msgstr "ਇਹ ਉਹ ਸੁਨੇਹਾ ਹੈ ਜੋ ਵਿਦਿਆਰਥੀ ਡਰਾਫਟ ਜਵਾਬ ਜਮ੍ਹਾਂ ਕਰਨ 'ਤੇ ਦੇਖਣਗੇ।"

#: templates/view.html:15
msgid ""
"Allow my response to possibly be visible by other learners after submitting "
"their response"
msgstr ""
"ਮੇਰਾ ਜਵਾਬ ਦੂਜੇ ਸਿਖਿਆਰਥੀਆਂ ਦੁਆਰਾ ਆਪਣਾ ਜਵਾਬ ਜਮ੍ਹਾਂ ਕਰਨ ਤੋਂ ਬਾਅਦ ਦਿਖਾਈ ਦੇਣ ਦਿਓ।"

#: templates/view.html:21 templates/view.html:24
msgid "Checking..."
msgstr "ਜਾਂਚ ਕੀਤੀ ਜਾ ਰਹੀ ਹੈ..."

#: templates/view.html:21 templates/view.html:22
msgid "Submit"
msgstr "ਜਮ੍ਹਾਂ ਕਰੋ"

#: templates/view.html:24 templates/view.html:25
msgid "Save"
msgstr "ਸੇਵ ਕਰੋ"

#: templates/view.html:34
msgid "Hide"
msgstr "ਲੁਕਾਓ"

#: templates/view.html:35
msgid "Show"
msgstr "ਦਿਖਾਓ"

#: templates/view.html:36
msgid "peer responses"
msgstr "ਸਾਥੀਆਂ ਦੇ ਜਵਾਬ"

#: templates/view.html:38
msgid "Submissions by others"
msgstr "ਦੂਜਿਆਂ ਦੁਆਰਾ ਸਪੁਰਦਗੀਆਂ"

#: templates/view.html:39 templates/view.html:43
msgid "No responses to show at this time"
msgstr "ਇਸ ਵੇਲੇ ਦਿਖਾਉਣ ਲਈ ਕੋਈ ਜਵਾਬ ਨਹੀਂ ਹੈ"

#: views.py:126
#, python-brace-format
msgid "{weight} point possible"
msgid_plural "{weight} points possible"
msgstr[0] "{weight} ਪੁਆਇੰਟ ਸੰਭਵ ਹੈ"
msgstr[1] "{weight} ਪੁਆਇੰਟ ਸੰਭਵ ਹੈ"

#: views.py:134
#, python-brace-format
msgid "{score_string}/{weight} point"
msgid_plural "{score_string}/{weight} points"
msgstr[0] "{score_string}/{weight} ਪੁਆਇੰਟ"
msgstr[1] "{score_string}/{weight} ਪੁਆਇੰਟ"

#: views.py:147
#, python-brace-format
msgid "You have used {count_attempts} of {max_attempts} submission"
msgid_plural "You have used {count_attempts} of {max_attempts} submissions"
msgstr[0] ""
"ਤੁਸੀਂ {max_attempts} ਵਿੱਚੋਂ {count_attempts} ਸਬਮਿਸ਼ਨ ਦੀ ਵਰਤੋਂ ਕੀਤੀ ਹੈ।"
msgstr[1] ""
"ਤੁਸੀਂ {max_attempts} ਵਿੱਚੋਂ {count_attempts} ਸਬਮਿਸ਼ਨ ਦੀ ਵਰਤੋਂ ਕੀਤੀ ਹੈ।"

#: views.py:171
#, python-brace-format
msgid "Your response must be between {min} and {max} word."
msgid_plural "Your response must be between {min} and {max} words."
msgstr[0] ""
"ਤੁਹਾਡਾ ਜਵਾਬ {min} ਅਤੇ {max} ਸ਼ਬਦਾਂ ਦੇ ਵਿਚਕਾਰ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"
msgstr[1] ""
"ਤੁਹਾਡਾ ਜਵਾਬ {min} ਅਤੇ {max} ਸ਼ਬਦਾਂ ਦੇ ਵਿਚਕਾਰ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"

#: views.py:267
#, python-brace-format
msgid "Invalid Word Count. {word_count_message}"
msgstr "ਗਲਤ ਸ਼ਬਦ ਗਿਣਤੀ। {word_count_message}"
