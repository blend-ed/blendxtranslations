#: lms/djangoapps/instructor/views/api.py:2672
msgid "URL from which report can be downloaded."
msgstr "ਉਹ URL ਜਿਸ ਤੋਂ ਰਿਪੋਰਟ ਡਾਊਨਲੋਡ ਕੀਤੀ ਜਾ ਸਕਦੀ ਹੈ।"

#: lms/djangoapps/instructor/views/api.py:2673
