msgstr ""
"ਕੋਈ ਗਲਤੀ ਹੋਈ ਹੈ। ਪੰਨੇ ਨੂੰ ਤਾਜ਼ਾ ਕਰਨ ਦੀ ਕੋਸ਼ਿਸ਼ ਕਰੋ, ਜਾਂ ਆਪਣੇ ਇੰਟਰਨੈੱਟ "
"ਕਨੈਕਸ਼ਨ ਦੀ ਜਾਂਚ ਕਰੋ।"

#: openedx/core/djangoapps/user_authn/views/register.py:186
#, python-brace-format
msgid "Registration using {provider} has timed out."
msgstr "{provider} ਦੀ ਵਰਤੋਂ ਕਰਕੇ ਰਜਿਸਟ੍ਰੇਸ਼ਨ ਦਾ ਸਮਾਂ ਸਮਾਪਤ ਹੋ ਗਿਆ ਹੈ।"

#: openedx/core/djangoapps/user_authn/views/register.py:329
msgid "An access_token is required when passing value ({}) for provider."
msgstr "ਪ੍ਰਦਾਤਾ ਲਈ ਮੁੱਲ ({}) ਪਾਸ ਕਰਨ ਵੇਲੇ ਇੱਕ ਐਕਸੈਸ_ਟੋਕਨ ਦੀ ਲੋੜ ਹੁੰਦੀ ਹੈ।"

#: openedx/core/djangoapps/user_authn/views/register.py:342
