#. Translators: 'closed' means the problem's due date has passed. You may no
#. longer attempt to solve the problem.
#: xmodule/capa_block.py:1802 xmodule/capa_block.py:2130
msgid "Problem is closed."
msgstr "ਸਮੱਸਿਆ ਬੰਦ ਹੋ ਗਈ ਹੈ।"

#: xmodule/capa_block.py:1808
msgid "Problem must be reset before it can be submitted again."
msgstr "ਸਮੱਸਿਆ ਨੂੰ ਦੁਬਾਰਾ ਦਰਜ ਕਰਨ ਤੋਂ ਪਹਿਲਾਂ ਇਸਨੂੰ ਰੀਸੈਟ ਕਰਨਾ ਲਾਜ਼ਮੀ ਹੈ।"

#: xmodule/capa_block.py:1818
#, python-brace-format
msgid "You must wait at least {wait} seconds between submissions."
msgstr "ਤੁਹਾਨੂੰ ਸਬਮਿਸ਼ਨਾਂ ਵਿਚਕਾਰ ਘੱਟੋ-ਘੱਟ {wait} ਸਕਿੰਟ ਉਡੀਕ ਕਰਨੀ ਪਵੇਗੀ।"

#: xmodule/capa_block.py:1827
#, python-brace-format
msgid ""
"You must wait at least {wait_secs} between submissions. {remaining_secs} "
"remaining."
msgstr ""
"ਤੁਹਾਨੂੰ ਸਪੁਰਦਗੀਆਂ ਦੇ ਵਿਚਕਾਰ ਘੱਟੋ-ਘੱਟ {wait_secs} ਉਡੀਕ ਕਰਨੀ ਪਵੇਗੀ। "
"{remaining_secs} ਬਾਕੀ ਹਨ।"

