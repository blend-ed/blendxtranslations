msgstr "ਪਾਸਵਰਡ ਬਦਲਣ ਦੌਰਾਨ ਕੁਝ ਗਲਤੀ ਹੋਈ। ਕਿਰਪਾ ਕਰਕੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:668
msgid "No email address provided."
msgstr "ਕੋਈ ਈਮੇਲ ਪਤਾ ਨਹੀਂ ਦਿੱਤਾ ਗਿਆ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:746
msgid ""
"An error has occurred. Try refreshing the page, or check your internet "
