msgstr "ਰਿਪੋਰਟ ਦਾ ਨਾਮ।"

#: lms/djangoapps/instructor/views/api.py:2674
msgid "HTML anchor tag that contains the name and link."
msgstr "HTML ਐਂਕਰ ਟੈਗ ਜਿਸ ਵਿੱਚ ਨਾਮ ਅਤੇ ਲਿੰਕ ਹੁੰਦਾ ਹੈ।"

#: lms/djangoapps/instructor/views/api.py:2683
msgid "List of report downloads"
msgstr "ਰਿਪੋਰਟ ਡਾਊਨਲੋਡਾਂ ਦੀ ਸੂਚੀ"

#: lms/djangoapps/instructor/views/api.py:2697
msgid "ID for the course whose reports need to be listed."
msgstr "ਉਸ ਕੋਰਸ ਲਈ ਆਈਡੀ ਜਿਸ ਦੀਆਂ ਰਿਪੋਰਟਾਂ ਨੂੰ ਸੂਚੀਬੱਧ ਕਰਨ ਦੀ ਲੋੜ ਹੈ।"

#: lms/djangoapps/instructor/views/api.py:2703
msgid ""
"Filter results to only return details of for the report with the specified "
