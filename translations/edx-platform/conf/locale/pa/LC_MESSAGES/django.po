msgstr "ਯੂਜ਼ਰਨੇਮ@ਡੋਮੇਨ.ਕਾਮ"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:183
msgid ""
"That e-mail address doesn't have an associated user account. Are you sure "
"you've registered?"
msgstr ""
"ਉਸ ਈਮੇਲ ਪਤੇ ਨਾਲ ਕੋਈ ਸੰਬੰਧਿਤ ਉਪਭੋਗਤਾ ਖਾਤਾ ਨਹੀਂ ਹੈ। ਕੀ ਤੁਸੀਂ ਪੱਕਾ ਰਜਿਸਟਰ ਕੀਤਾ "
"ਹੈ?"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:185
msgid ""
"The user account associated with this e-mail address cannot reset the "
"password."
msgstr "ਇਸ ਈ-ਮੇਲ ਪਤੇ ਨਾਲ ਜੁੜਿਆ ਯੂਜ਼ਰ ਖਾਤਾ ਪਾਸਵਰਡ ਰੀਸੈਟ ਨਹੀਂ ਕਰ ਸਕਦਾ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:307
#: openedx/core/djangoapps/user_authn/views/password_reset.py:630
msgid ""
"Your previous request is in progress, please try again in a few moments."
msgstr ""
"ਤੁਹਾਡੀ ਪਿਛਲੀ ਬੇਨਤੀ ਪ੍ਰਗਤੀ ਅਧੀਨ ਹੈ, ਕਿਰਪਾ ਕਰਕੇ ਕੁਝ ਪਲਾਂ ਵਿੱਚ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ "
"ਕਰੋ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:414
#: openedx/core/djangoapps/user_authn/views/password_reset.py:429
msgid "Password reset unsuccessful"
msgstr "ਪਾਸਵਰਡ ਰੀਸੈੱਟ ਅਸਫਲ ਰਿਹਾ"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:415
msgid "Error in resetting your password."
msgstr "ਤੁਹਾਡਾ ਪਾਸਵਰਡ ਰੀਸੈੱਟ ਕਰਨ ਵਿੱਚ ਗਲਤੀ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:445
msgid "Error in resetting your password. Please try again."
msgstr "ਤੁਹਾਡਾ ਪਾਸਵਰਡ ਰੀਸੈੱਟ ਕਰਨ ਵਿੱਚ ਗਲਤੀ। ਕਿਰਪਾ ਕਰਕੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:470
#, python-brace-format
msgid ""
"{html_start}Password Creation Complete{html_end}Your password has been "
"created. {bold_start}{email}{bold_end} is now your primary login email."
msgstr ""
"{html_start}ਪਾਸਵਰਡ ਬਣਾਉਣਾ ਪੂਰਾ ਹੋਇਆ{html_end}ਤੁਹਾਡਾ ਪਾਸਵਰਡ ਬਣਾ ਲਿਆ ਗਿਆ ਹੈ। "
"{bold_start}{email}{bold_end} ਹੁਣ ਤੁਹਾਡਾ ਪ੍ਰਾਇਮਰੀ ਲੌਗਇਨ ਈਮੇਲ ਹੈ।"

#: openedx/core/djangoapps/user_authn/views/password_reset.py:664
