#: models.py:24
msgid "Display Name:"
msgstr "ਦਿਖਾਇਆ ਹੋਇਆ ਨਾਮ:"

#: models.py:28
msgid "This name appears in the horizontal navigation at the top of the page."
msgstr "ਇਹ ਨਾਮ ਪੰਨੇ ਦੇ ਸਿਖਰ 'ਤੇ ਖਿਤਿਜੀ ਨੈਵੀਗੇਸ਼ਨ ਵਿੱਚ ਦਿਖਾਈ ਦਿੰਦਾ ਹੈ।"

#: models.py:33
msgid "Link Text:"
msgstr "ਲਿੰਕ ਟੈਕਸਟ:"

#: models.py:36
msgid "This is the text that will link to your survey."
msgstr "ਇਹ ਉਹ ਟੈਕਸਟ ਹੈ ਜੋ ਤੁਹਾਡੇ ਸਰਵੇਖਣ ਨਾਲ ਲਿੰਕ ਹੋਵੇਗਾ।"

#: models.py:39
msgid "Message:"
msgstr "ਸੁਨੇਹਾ:"

#: models.py:43
msgid "This is the text that will be displayed above the link to your survey."
msgstr "ਇਹ ਉਹ ਟੈਕਸਟ ਹੈ ਜੋ ਤੁਹਾਡੇ ਸਰਵੇਖਣ ਦੇ ਲਿੰਕ ਦੇ ਉੱਪਰ ਪ੍ਰਦਰਸ਼ਿਤ ਹੋਵੇਗਾ।"

#: models.py:48
msgid "Param Name:"
msgstr "ਪਰਮ ਨਾਮ:"

#: models.py:52
msgid ""
"This is the name for the User ID parameter in the url. If blank, User ID is "
"ommitted from the url."
msgstr ""
"ਇਹ url ਵਿੱਚ ਯੂਜ਼ਰ ਆਈਡੀ ਪੈਰਾਮੀਟਰ ਦਾ ਨਾਮ ਹੈ। ਜੇਕਰ ਖਾਲੀ ਹੈ, ਤਾਂ ਯੂਜ਼ਰ ਆਈਡੀ url "
"ਤੋਂ ਹਟਾ ਦਿੱਤੀ ਜਾਂਦੀ ਹੈ।"

#: models.py:57
msgid "Survey ID:"
msgstr "ਸਰਵੇਖਣ ਆਈਡੀ:"

#: models.py:61
msgid ""
"This is the ID that Qualtrics uses for the survey, which can include numbers"
" and letters, and should be entered in the following format: "
"SV_###############"
msgstr ""
"ਇਹ ਉਹ ਆਈਡੀ ਹੈ ਜੋ ਕੁਆਲਟ੍ਰਿਕਸ ਸਰਵੇਖਣ ਲਈ ਵਰਤਦਾ ਹੈ, ਜਿਸ ਵਿੱਚ ਨੰਬਰ ਅਤੇ ਅੱਖਰ ਸ਼ਾਮਲ"
" ਹੋ ਸਕਦੇ ਹਨ, ਅਤੇ ਇਸਨੂੰ ਹੇਠ ਦਿੱਤੇ ਫਾਰਮੈਟ ਵਿੱਚ ਦਰਜ ਕੀਤਾ ਜਾਣਾ ਚਾਹੀਦਾ ਹੈ: "
"SV_#################"

#: models.py:67
msgid "Your University:"
msgstr "ਤੁਹਾਡੀ ਯੂਨੀਵਰਸਿਟੀ:"

#: models.py:70
msgid "This is the name of your university."
msgstr "ਇਹ ਤੁਹਾਡੀ ਯੂਨੀਵਰਸਿਟੀ ਦਾ ਨਾਮ ਹੈ।"
