#: models.py:25
msgid "Display Name"
msgstr "ਦਿਖਾਇਆ ਹੋਇਆ ਨਾਮ"

#: models.py:28
msgid "This is the XBlock's display name"
msgstr "ਇਹ XBlock ਦਾ ਡਿਸਪਲੇ ਨਾਮ ਹੈ।"

#: models.py:32
msgid "Image URL"
msgstr "ਚਿੱਤਰ URL"

#: models.py:41
msgid "This is the location of the full-screen image to be displayed."
msgstr "ਇਹ ਪੂਰੀ-ਸਕ੍ਰੀਨ ਚਿੱਤਰ ਦੀ ਸਥਿਤੀ ਹੈ ਜਿੱਥੇ ਪ੍ਰਦਰਸ਼ਿਤ ਕੀਤਾ ਜਾਣਾ ਹੈ।"

#: models.py:46
msgid "Thumbnail URL"
msgstr "ਥੰਬਨੇਲ URL"

#: models.py:50
msgid ""
"This is the (optional) location of a thumbnail image to be displayed before "
"the main image has been enlarged."
msgstr ""
"ਇਹ ਥੰਬਨੇਲ ਚਿੱਤਰ ਦਾ (ਵਿਕਲਪਿਕ) ਸਥਾਨ ਹੈ ਜਿੱਥੇ ਮੁੱਖ ਚਿੱਤਰ ਨੂੰ ਵੱਡਾ ਕਰਨ ਤੋਂ "
"ਪਹਿਲਾਂ ਪ੍ਰਦਰਸ਼ਿਤ ਕੀਤਾ ਜਾਣਾ ਹੈ।"

#: models.py:56
msgid "Description"
msgstr "ਵੇਰਵਾ"

#: models.py:59
msgid "Description text, displayed to screen readers"
msgstr "ਵਰਣਨ ਲਿਖਤ, ਸਕ੍ਰੀਨ ਰੀਡਰਾਂ ਨੂੰ ਦਿਖਾਈ ਜਾਂਦੀ ਹੈ"

#: models.py:64
msgid "Alt Text"
msgstr "ਵਿਕਲਪਿਕ ਟੈਕਸਟ"

#: models.py:68
msgid ""
"This field allows you to add alternate or descriptive text that pertains to "
"your image."
msgstr ""
"ਇਹ ਖੇਤਰ ਤੁਹਾਨੂੰ ਤੁਹਾਡੀ ਤਸਵੀਰ ਨਾਲ ਸੰਬੰਧਿਤ ਵਿਕਲਪਿਕ ਜਾਂ ਵਰਣਨਾਤਮਕ ਟੈਕਸਟ ਜੋੜਨ ਦੀ "
"ਆਗਿਆ ਦਿੰਦਾ ਹੈ।"

#: templates/view.html:15
msgid "Fullscreen"
msgstr "ਪੂਰਾ ਸਕਰੀਨ"

#: templates/view.html:25
msgid "Zoom In"
msgstr "ਜ਼ੂਮ ਇਨ ਕਰੋ"

#: templates/view.html:29
msgid "Close"
msgstr "ਬੰਦ ਕਰੋ"
