msgstr "'{key}' ਕੁੰਜੀ ਨਹੀਂ ਮਿਲੀ।"

#: api/v1/views.py:97
msgid "User is not enrolled in course."
msgstr "ਵਰਤੋਂਕਾਰ ਕੋਰਸ ਵਿੱਚ ਦਰਜ ਨਹੀਂ ਹੈ।"

#: api/v1/views.py:115
