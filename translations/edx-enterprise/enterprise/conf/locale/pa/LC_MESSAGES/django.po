#: consent/admin/__init__.py:99
msgid ""
"Preview the data sharing consent page rendered in the context of a course "
"enrollment."
msgstr ""
"ਕੋਰਸ ਦਾਖਲੇ ਦੇ ਸੰਦਰਭ ਵਿੱਚ ਪੇਸ਼ ਕੀਤੇ ਗਏ ਡੇਟਾ ਸਾਂਝਾਕਰਨ ਸਹਿਮਤੀ ਪੰਨੇ ਦਾ ਪੂਰਵਦਰਸ਼ਨ"
" ਕਰੋ।"

#: consent/admin/__init__.py:110
msgid ""
"Preview the data sharing consent page rendered in the context of a program "
"enrollment."
msgstr ""
"ਪ੍ਰੋਗਰਾਮ ਨਾਮਾਂਕਣ ਦੇ ਸੰਦਰਭ ਵਿੱਚ ਪੇਸ਼ ਕੀਤੇ ਗਏ ਡੇਟਾ ਸਾਂਝਾਕਰਨ ਸਹਿਮਤੀ ਪੰਨੇ ਦਾ "
"ਪੂਰਵਦਰਸ਼ਨ ਕਰੋ।"

#: consent/admin/__init__.py:119 enterprise/admin/__init__.py:721
msgid "Preview (course)"
msgstr "ਪੂਰਵਦਰਸ਼ਨ (ਕੋਰਸ)"

#: consent/admin/__init__.py:120 enterprise/admin/__init__.py:734
msgid "Preview (program)"
msgstr "ਪੂਰਵਦਰਸ਼ਨ (ਪ੍ਰੋਗਰਾਮ)"

#: consent/models.py:213
msgid "Name of the user whose consent state is stored."
msgstr "ਉਸ ਵਰਤੋਂਕਾਰ ਦਾ ਨਾਮ ਜਿਸਦੀ ਸਹਿਮਤੀ ਸਥਿਤੀ ਸਟੋਰ ਕੀਤੀ ਗਈ ਹੈ।"

#: consent/models.py:215
msgid "Whether consent is granted."
msgstr "ਕੀ ਸਹਿਮਤੀ ਦਿੱਤੀ ਜਾਂਦੀ ਹੈ।"

#: consent/models.py:243
msgid "Data Sharing Consent Record"
msgstr "ਡਾਟਾ ਸਾਂਝਾਕਰਨ ਸਹਿਮਤੀ ਰਿਕਾਰਡ"

#: consent/models.py:244
msgid "Data Sharing Consent Records"
msgstr "ਡਾਟਾ ਸਾਂਝਾਕਰਨ ਸਹਿਮਤੀ ਰਿਕਾਰਡ"

#: consent/models.py:252
msgid "Course key for which data sharing consent is granted."
msgstr "ਕੋਰਸ ਕੁੰਜੀ ਜਿਸ ਲਈ ਡੇਟਾ ਸਾਂਝਾ ਕਰਨ ਦੀ ਸਹਿਮਤੀ ਦਿੱਤੀ ਜਾਂਦੀ ਹੈ।"

#: consent/models.py:266
msgid "Data sharing consent text overrides"
msgstr "ਡਾਟਾ ਸਾਂਝਾਕਰਨ ਸਹਿਮਤੀ ਲਿਖਤ ਓਵਰਰਾਈਡ ਕਰਦੀ ਹੈ"

#: consent/models.py:269
msgid ""
"Fill in a text for first paragraph of page. The following variables may be "
"available:<br /><ul><li>enterprise_customer_name: A name of enterprise "
"customer.</li><li>platform_name: Name of platform.</li><li>item: A string "
"which is \"course\" or \"program\" depending on the type of "
"consent.</li><li>course_title: Title of course. Available when type of "
"consent is course.</li><li>course_start_date: Course start date. Available "
"when type of consent is course.</li></ul>"
msgstr ""
"ਪੰਨੇ ਦੇ ਪਹਿਲੇ ਪੈਰੇ ਲਈ ਇੱਕ ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਲਿਖੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ ਸਕਦੇ ਹਨ:<br "
"/><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ "
"ਨਾਮ।</li><li>platform_name: ਪਲੇਟਫਾਰਮ ਦਾ ਨਾਮ।</li><li>ਆਈਟਮ: ਇੱਕ ਸਤਰ ਜੋ ਸਹਿਮਤੀ"
" ਦੀ ਕਿਸਮ ਦੇ ਅਧਾਰ ਤੇ \"ਕੋਰਸ\" ਜਾਂ \"ਪ੍ਰੋਗਰਾਮ\" ਹੈ।</li><li>course_title: ਕੋਰਸ"
" ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li><li>course_start_date: "
"ਕੋਰਸ ਸ਼ੁਰੂ ਹੋਣ ਦੀ ਮਿਤੀ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:279
msgid ""
"Fill in a text for policy paragraph at the bottom of page. The following "
"variables may be available:<br /><ul><li>enterprise_customer_name: A name of"
" enterprise customer.</li><li>platform_name: Name of platform.</li><li>item:"
" A string which is \"course\" or \"program\" depending on the type of "
"consent.</li><li>course_title: Title of course. Available when type of "
"consent is course.</li><li>course_start_date: Course start date. Available "
"when type of consent is course.</li></ul>"
msgstr ""
"ਪੰਨੇ ਦੇ ਹੇਠਾਂ ਨੀਤੀ ਪੈਰਾਗ੍ਰਾਫ ਲਈ ਇੱਕ ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਦਿੱਤੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ "
"ਸਕਦੇ ਹਨ:<br /><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ "
"ਨਾਮ।</li><li>platform_name: ਪਲੇਟਫਾਰਮ ਦਾ ਨਾਮ।</li><li>ਆਈਟਮ: ਇੱਕ ਸਤਰ ਜੋ ਸਹਿਮਤੀ"
" ਦੀ ਕਿਸਮ ਦੇ ਅਧਾਰ ਤੇ \"ਕੋਰਸ\" ਜਾਂ \"ਪ੍ਰੋਗਰਾਮ\" ਹੈ।</li><li>course_title: ਕੋਰਸ"
" ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li><li>course_start_date: "
"ਕੋਰਸ ਸ਼ੁਰੂ ਹੋਣ ਦੀ ਮਿਤੀ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:289
msgid ""
"Fill in a text for left sidebar paragraph. The following variables may be "
"available:<br /><ul><li>enterprise_customer_name: A name of enterprise "
"customer.</li><li>platform_name: Name of platform.</li><li>item: A string "
"which is \"course\" or \"program\" depending on the type of "
"consent.</li><li>course_title: Title of course. Available when type of "
"consent is course.</li><li>course_start_date: Course start date. Available "
"when type of consent is course.</li></ul>"
msgstr ""
"ਖੱਬੇ ਸਾਈਡਬਾਰ ਪੈਰਾਗ੍ਰਾਫ ਲਈ ਇੱਕ ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਦਿੱਤੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ ਸਕਦੇ "
"ਹਨ:<br /><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ "
"ਨਾਮ।</li><li>platform_name: ਪਲੇਟਫਾਰਮ ਦਾ ਨਾਮ।</li><li>ਆਈਟਮ: ਇੱਕ ਸਤਰ ਜੋ ਸਹਿਮਤੀ"
" ਦੀ ਕਿਸਮ ਦੇ ਅਧਾਰ ਤੇ \"ਕੋਰਸ\" ਜਾਂ \"ਪ੍ਰੋਗਰਾਮ\" ਹੈ।</li><li>course_title: ਕੋਰਸ"
" ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li><li>course_start_date: "
"ਕੋਰਸ ਸ਼ੁਰੂ ਹੋਣ ਦੀ ਮਿਤੀ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:299
msgid ""
"Fill in a text for dialog which appears when user decline to provide "
"consent. The following variables may be available:<br "
"/><ul><li>enterprise_customer_name: A name of enterprise "
"customer.</li><li>item: A string which is \"course\" or \"program\" "
"depending on the type of consent.</li><li>course_title: Title of course. "
"Available when type of consent is course.</li><li>course_start_date: Course "
"start date. Available when type of consent is course.</li></ul>"
msgstr ""
"ਜਦੋਂ ਉਪਭੋਗਤਾ ਸਹਿਮਤੀ ਦੇਣ ਤੋਂ ਇਨਕਾਰ ਕਰਦਾ ਹੈ ਤਾਂ ਦਿਖਾਈ ਦੇਣ ਵਾਲੇ ਡਾਇਲਾਗ ਲਈ ਇੱਕ "
"ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਲਿਖੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ ਸਕਦੇ ਹਨ:<br "
"/><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ ਨਾਮ।</li><li>ਆਈਟਮ: "
"ਇੱਕ ਸਤਰ ਜੋ ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਦੇ ਅਧਾਰ ਤੇ \"ਕੋਰਸ\" ਜਾਂ \"ਪ੍ਰੋਗਰਾਮ\" "
"ਹੈ।</li><li>course_title: ਕੋਰਸ ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ "
"ਉਪਲਬਧ।</li><li>course_start_date: ਕੋਰਸ ਦੀ ਸ਼ੁਰੂਆਤ ਦੀ ਮਿਤੀ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ "
"ਕੋਰਸ ਹੋਣ 'ਤੇ ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:309
msgid ""
"Fill in a text for title of the notification which appears on dashboard when"
" user decline to provide consent. The following variables may be "
"available:<br /><ul><li>enterprise_customer_name: A name of enterprise "
"customer.</li><li>course_title: Title of course. Available when type of "
"consent is course.</li></ul>"
msgstr ""
"ਜਦੋਂ ਉਪਭੋਗਤਾ ਸਹਿਮਤੀ ਦੇਣ ਤੋਂ ਇਨਕਾਰ ਕਰਦਾ ਹੈ ਤਾਂ ਡੈਸ਼ਬੋਰਡ 'ਤੇ ਦਿਖਾਈ ਦੇਣ ਵਾਲੀ "
"ਸੂਚਨਾ ਦੇ ਸਿਰਲੇਖ ਲਈ ਇੱਕ ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਲਿਖੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ ਸਕਦੇ ਹਨ:<br "
"/><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ "
"ਨਾਮ।</li><li>course_title: ਕੋਰਸ ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ "
"ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:318
msgid ""
"Fill in a text for message of the notification which appears on dashboard "
"when user decline to provide consent. The following variables may be "
"available:<br /><ul><li>enterprise_customer_name: A name of enterprise "
"customer.</li><li>course_title: Title of course. Available when type of "
"consent is course.</li></ul>"
msgstr ""
"ਜਦੋਂ ਉਪਭੋਗਤਾ ਸਹਿਮਤੀ ਦੇਣ ਤੋਂ ਇਨਕਾਰ ਕਰਦਾ ਹੈ ਤਾਂ ਡੈਸ਼ਬੋਰਡ 'ਤੇ ਦਿਖਾਈ ਦੇਣ ਵਾਲੀ "
"ਸੂਚਨਾ ਦੇ ਸੁਨੇਹੇ ਲਈ ਇੱਕ ਟੈਕਸਟ ਭਰੋ। ਹੇਠ ਲਿਖੇ ਵੇਰੀਏਬਲ ਉਪਲਬਧ ਹੋ ਸਕਦੇ ਹਨ:<br "
"/><ul><li>enterprise_customer_name: ਐਂਟਰਪ੍ਰਾਈਜ਼ ਗਾਹਕ ਦਾ "
"ਨਾਮ।</li><li>course_title: ਕੋਰਸ ਦਾ ਸਿਰਲੇਖ। ਸਹਿਮਤੀ ਦੀ ਕਿਸਮ ਕੋਰਸ ਹੋਣ 'ਤੇ "
"ਉਪਲਬਧ।</li></ul>"

#: consent/models.py:329
msgid "Title of page"
msgstr "ਪੰਨੇ ਦਾ ਸਿਰਲੇਖ"

#: consent/models.py:344
